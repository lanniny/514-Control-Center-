        "customize": "skills/research/grok-researcher/customize.toml"
      },
      "embedded-expert": {
        "name": "匠",
        "title": "老匠人",
        "source": "skills/domain/embedded-expert/SKILL.md",
        "customize": "skills/domain/embedded-expert/customize.toml"
      },
      "spec-architect": {
        "name": "策",
        "title": "军师",
        "source": "skills/domain/spec-architect/SKILL.md",
        "customize": "skills/domain/spec-architect/customize.toml"
      },
      "meta-reviewer": {
        "name": "鉴",
