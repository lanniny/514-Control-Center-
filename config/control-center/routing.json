{
  "$schema": "../../schemas/control-center/contracts.schema.json#/$defs/routingPolicy",
  "version": 1,
  "primaryCoordinator": "claude-fable",
  "technicalExecutor": "codex-technical",
  "maxRounds": 6,
  "maxDepth": 2,
  "maxParallelAgents": 4,
  "requireHealthyProvider": true,
  "failOnUnavailableExplicitProvider": true,
  "weights": {"capability": 0.46, "quality": 0.24, "speed": 0.14, "health": 0.12, "cost": 0.04},
  "rules": [
    {"id": "plan-primary", "taskTypes": ["planning", "requirements", "coordination"], "prefer": ["claude-fable"]},
    {"id": "technical-codex", "taskTypes": ["coding", "debugging", "review", "architecture", "testing"], "prefer": ["codex-technical"]},
    {"id": "current-grok", "taskTypes": ["current-research", "web-search"], "prefer": ["grok-search"]},
    {"id": "long-gemini", "taskTypes": ["long-context", "multimodal", "document-analysis"], "prefer": ["gemini-research"]},
    {"id": "resident-pi", "taskTypes": ["resident-session", "extension-work"], "prefer": ["pi-resident"]}
  ],
  "independentPass": {
    "requiredFor": ["high", "security", "production", "governance", "non-trivial-review"],
    "mustDifferFromPrimary": true,
    "capabilities": ["review", "architecture", "synthesis"]
  }
}
