{
  "$schema": "../../schemas/control-center/contracts.schema.json#/$defs/sourceRegistry",
  "version": 1,
  "explicit": [
    {"id": "control.models", "path": "config/control-center/models.json", "label": "模型能力注册表", "kind": "json", "scope": "repo", "critical": true},
    {"id": "control.routing", "path": "config/control-center/routing.json", "label": "动态路由策略", "kind": "json", "scope": "repo", "critical": true},
    {"id": "control.permissions", "path": "config/control-center/permissions.json", "label": "权限与预算策略", "kind": "json", "scope": "repo", "critical": true},
    {"id": "control.claude-coordinator", "path": "config/control-center/claude-coordinator.md", "label": "Fable 主脑系统提示词", "kind": "markdown", "scope": "repo", "critical": true},
    {"id": "control.sources", "path": "config/control-center/sources.json", "label": "配置真源注册表", "kind": "json", "scope": "repo", "critical": true},
    {"id": "control.contracts", "path": "schemas/control-center/contracts.schema.json", "label": "控制面契约 Schema", "kind": "json", "scope": "repo", "critical": true},
    {"id": "core.rules", "path": "rules.md", "label": "514cc 宪法", "kind": "markdown", "scope": "repo", "critical": true},
    {"id": "core.module", "path": "module.yaml", "label": "模块注册表", "kind": "yaml", "scope": "repo", "critical": true},
    {"id": "core.agents", "path": "AGENTS.md", "label": "Codex 项目指令", "kind": "markdown", "scope": "repo", "critical": true},
    {"id": "core.claude", "path": "CLAUDE.md", "label": "Claude 项目指令", "kind": "markdown", "scope": "repo", "critical": true},
    {"id": "core.readme", "path": "README.md", "label": "项目说明", "kind": "markdown", "scope": "repo", "critical": false},
    {"id": "core.plugin-manifest", "path": ".claude-plugin/plugin.json", "label": "Claude 插件清单", "kind": "json", "scope": "repo", "critical": true},
    {"id": "core.codex-config", "path": ".codex/config.toml", "label": "Codex 项目配置", "kind": "toml", "scope": "repo", "critical": true}
  ],
  "discover": [
    {"root": "customize", "extensions": [".toml", ".md"], "critical": false},
    {"root": "skills", "names": ["SKILL.md", "customize.toml"], "critical": false},
    {"root": ".agents/skills", "names": ["SKILL.md", "customize.toml"], "critical": false},
    {"root": ".codex/agents", "extensions": [".toml"], "critical": true},
    {"root": ".codex/instructions", "extensions": [".md"], "critical": true},
    {"root": ".codex/hooks", "extensions": [".py", ".md"], "critical": true},
    {"root": ".claude", "extensions": [".json", ".py", ".md"], "critical": true},
    {"root": ".cursor", "extensions": [".json", ".md", ".mdc"], "critical": true},
    {"root": "guardrails", "extensions": [".md", ".txt", ".yaml", ".yml"], "critical": true},
    {"root": "lilith", "extensions": [".md", ".json", ".yaml", ".yml"], "critical": false},
    {"root": "output-styles", "extensions": [".md"], "critical": true},
    {"root": "statusline", "extensions": [".toml", ".md"], "critical": false}
  ],
  "runtime": [
    {"id": "runtime.ai-collab-rules", "path": "${USERPROFILE}/.ai-collab/rules.md", "label": "宪法运行时（双地落）", "kind": "markdown", "scope": "runtime", "writePolicy": "deploy-only", "exposeContent": false, "sensitive": false},
    {"id": "runtime.claude-settings", "path": "${USERPROFILE}/.claude/settings.json", "label": "Claude 用户设置", "kind": "json", "scope": "runtime", "writePolicy": "deploy-only", "exposeContent": false, "sensitive": true},
    {"id": "runtime.claude-local-settings", "path": "${USERPROFILE}/.claude/settings.local.json", "label": "Claude 本地覆盖", "kind": "json", "scope": "runtime", "writePolicy": "deploy-only", "exposeContent": false, "sensitive": true},
    {"id": "runtime.codex-config", "path": "${USERPROFILE}/.codex/config.toml", "label": "Codex 用户配置", "kind": "toml", "scope": "runtime", "writePolicy": "deploy-only", "exposeContent": false, "sensitive": true},
    {"id": "runtime.codex-agents", "path": "${USERPROFILE}/.codex/AGENTS.md", "label": "Codex 用户指令", "kind": "markdown", "scope": "runtime", "writePolicy": "deploy-only", "exposeContent": false, "sensitive": false},
    {"id": "runtime.gemini-settings", "path": "${USERPROFILE}/.gemini/settings.json", "label": "Gemini 用户设置", "kind": "json", "scope": "runtime", "writePolicy": "deploy-only", "exposeContent": false, "sensitive": true},
    {"id": "runtime.pi-settings", "path": "${USERPROFILE}/.pi/agent/settings.json", "label": "Pi 用户设置", "kind": "json", "scope": "runtime", "writePolicy": "deploy-only", "exposeContent": false, "sensitive": true}
  ]
}
